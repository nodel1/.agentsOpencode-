#!/usr/bin/env bash

# post-push hook
# Detects changes after push and updates context files automatically

remote="$1"
url="$2"

z40=0000000000000000000000000000000000000000

while read local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "$z40" ]; then
        continue
    fi

    if echo "$remote_ref" | grep -q 'refs/heads/'; then
        branch_name=$(echo "$remote_ref" | sed 's|refs/heads/||')
        echo "Post-push: Detecting changes after push to $branch_name..."

        if [ "$remote_sha" != "$z40" ]; then
            changed_files=$(git diff --name-only "$remote_sha"...HEAD 2>/dev/null)
        else
            changed_files=$(git diff --name-only HEAD~1...HEAD 2>/dev/null)
        fi

        echo "Changed files: $changed_files"
        echo ""

        # Detect new context files
        new_context_files=$(echo "$changed_files" | grep "^context/" || true)
        if [ -n "$new_context_files" ]; then
            echo "New context files detected:"
            echo "$new_context_files"
            echo ""
        fi

        # Update folder structure in workflow-and-git.md if needed
        new_opencode_files=$(echo "$changed_files" | grep "\.opencode/" || true)
        if [ -n "$new_opencode_files" ]; then
            echo "OpenCode files changed - context may need update"
            echo ""
        fi

        echo "Context update note: Run 'opencode' and ask to update context if needed."
        echo "Or: 'Update our context files based on recent changes'"
    fi
done

exit 0