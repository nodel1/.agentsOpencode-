#!/usr/bin/env bash

# post-push hook
# Detects changes after push and records them for context-updater

remote="$1"
url="$2"

z40=0000000000000000000000000000000000000000

# File to store pending updates
PENDING_FILE="context/pending-updates.md"

while read local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "$z40" ]; then
        continue
    fi

    if echo "$remote_ref" | grep -q 'refs/heads/'; then
        branch_name=$(echo "$remote_ref" | sed 's|refs/heads/||')
        echo "Post-push: Recording changes after push to $branch_name..."

        # Get changed files
        if [ "$remote_sha" != "$z40" ]; then
            changed_files=$(git diff --name-only "$remote_sha"...HEAD 2>/dev/null)
        else
            changed_files=$(git diff --name-only HEAD~1...HEAD 2>/dev/null)
        fi

        # Get timestamp
        timestamp=$(date '+%Y-%m-%d %H:%M')

        # Escape special characters for markdown
        files_list=$(echo "$changed_files" | sed 's/^/- /')

        # Read existing content if file exists
        existing_last_push=""
        if [ -f "$PENDING_FILE" ]; then
            existing_last_push=$(grep -A5 "## Last Push" "$PENDING_FILE" | grep "Timestamp:" | cut -d':' -f2 | sed 's/^ *//')
        fi

        # Update the pending updates file
        cat > "$PENDING_FILE" << EOF
# Pending Context Updates

This file accumulates changes between bash pushes that don't go through the git-agent.

## Usage

When executing \`git push\` directly via bash:
- The post-push hook records changed files here
- The context-updater reads this file when invoked
- After processing, context-updater clears this file

## Last Push

**Timestamp:** $timestamp

**Changed files:**
$files_list

## Status

- \`pending_agent_review\` - Awaiting agent update
- \`cleared\` - Already processed

---

_Note: Do not edit manually. This file is managed by post-push hook and context-updater._
EOF

        echo "Context changes recorded in $PENDING_FILE"
        echo "Run 'opencode' and ask to update context files when ready."
    fi
done

exit 0